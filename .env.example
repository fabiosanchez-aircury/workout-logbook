# ── Local dev ─────────────────────────────────────────────────────────────────
# Run `make setup` to generate this file automatically with local dev values.
POSTGRES_PASSWORD=postgres
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# JWT keys — generated by `make setup` using JWT_SECRET above.
# Do NOT use real Supabase project keys here.
ANON_KEY=
SERVICE_ROLE_KEY=

# ── Google OAuth (optional — only needed for Google login) ────────────────────
GOOGLE_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
